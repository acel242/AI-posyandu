{
  "builds": [
    {
      "src": "api/proxy.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/proxy.py" },
    { "src": "/assets/(.*)", "dest": "/dashboard/dist/assets/$1" },
    { "src": "/", "dest": "/dashboard/dist/index.html" },
    { "src": "/(.*)", "dest": "/dashboard/dist/$1" }
  ]
}
