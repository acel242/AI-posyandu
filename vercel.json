{
  "version": 2,
  "builds": [
    {
      "src": "api/proxy.py",
      "use": "@vercel/python"
    },
    {
      "src": "dashboard/dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/proxy.py" },
    { "src": "/(.*)", "dest": "/dashboard/dist/$1" }
  ],
  "env": {
    "BACKEND_URL": "http://43.157.235.76:5001"
  }
}
