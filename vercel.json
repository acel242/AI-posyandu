{
  "version": 2,
  "builds": [
    {
      "src": "api/proxy.py",
      "use": "@vercel/python"
    },
    {
      "src": "dashboard/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/proxy.py" },
    { "src": "/(.*)", "dest": "/dashboard/$1" }
  ],
  "env": {
    "BACKEND_URL": "http://43.157.235.76:5001"
  }
}
