{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/handler/index.mjs" },
    { "source": "/(.*)", "destination": "/dashboard/dist/$1" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
