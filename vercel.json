{
  "version": 2,
  "builds": [
    {
      "src": "api/proxy.py",
      "use": "@vercel/python"
    },
    {
      "src": "dashboard/dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/proxy.py" },
    { "src": "/dashboard", "dest": "/dashboard/dist/index.html" },
    { "src": "/dashboard/(.*)", "dest": "/dashboard/dist/$1" },
    { "src": "/(.*)", "dest": "/dashboard/dist/index.html" }
  ]
}
